# ============================================
# ITERA Smart Sentinel - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env    (Linux/Mac)
#   Copy-Item .env.example .env   (PowerShell)

# --- Video Source ---
# RTSP stream or local file path
VIDEO_SOURCE=sample_video.mp4
# VIDEO_SOURCE=rtsp://admin:password@192.168.1.100:554/stream1

# --- Camera Info ---
CAMERA_ID=gate_utama_01
CAMERA_NAME=Gerbang Utama ITERA
CAMERA_LOCATION=Jalan Terusan Ryacudu, Gerbang Utama

# --- YOLOv8 Model ---
MODEL_PATH=models/best.pt
MODEL_CONFIDENCE=0.5
MODEL_IOU_THRESHOLD=0.45
# Gunakan "cpu" jika tidak punya NVIDIA GPU
MODEL_DEVICE=cpu
# MODEL_DEVICE=0     # CUDA device index (jika ada NVIDIA GPU)

# --- Violation Logic ---
VIOLATION_CONFIRM_FRAMES=3
ASSOCIATION_IOU_THRESHOLD=0.3

# --- Kafka ---
# Dari host (Python pipeline) → localhost:9092
# Dari Docker container (Spark) → kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

KAFKA_TOPIC_DETECTIONS=video.detections
KAFKA_TOPIC_VIOLATIONS=video.violations

# --- PostgreSQL (Local Docker) ---
# Dari host (Python pipeline) → localhost
# Dari Docker container → postgres
SUPABASE_DB_HOST=localhost
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=sentinel_db
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=localpassword

# --- Spark ---
SPARK_MASTER=local[2]
SPARK_DRIVER_MEMORY=2g
SPARK_CHECKPOINT_DIR=/tmp/sentinel-checkpoints

# --- Grafana ---
GRAFANA_URL=http://localhost:3000
